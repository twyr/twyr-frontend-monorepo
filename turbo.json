{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"@twyr/web-shell#build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**"]
		},
		"@twyr/web-users#build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**"]
		},
		"@twyr/web-system-administrators#build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**"]
		},
		"@twyr/mobile-shell#build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"@twyr/mobile-users#build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"@twyr/mobile-system-administrators#build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		}
	}
}
